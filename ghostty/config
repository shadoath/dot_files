# Ghostty config — symlink to ~/.config/ghostty/config
# Reload in-app with cmd+shift+, after edits.

# --- Appearance ---
theme = Catppuccin Mocha
font-family = "JetBrains Mono"
font-size = 14
# Soften the look a little; bump to taste.
background-opacity = 0.98
macos-titlebar-style = tabs

# --- Shell ---
# Ghostty's shell integration is automatic for zsh — no script to source.
# This replaces the .iterm2_shell_integration.zsh line in .zshrc.
shell-integration = zsh
# Note: 'cursor' is intentionally omitted — it lets zsh override cursor-style
# with a bar at the prompt. Leave it out to keep the block cursor everywhere.
shell-integration-features = sudo,title

# Rails logs are verbose; keep plenty of history.
scrollback-limit = 100000

# --- macOS behavior ---
# Lets you use option as a meta key while keeping accented chars on demand.
macos-option-as-alt = true
copy-on-select = clipboard
confirm-close-surface = true
quit-after-last-window-closed = true

# --- Quick terminal (dropdown, like iTerm2's hotkey window) ---
keybind = global:cmd+grave_accent=toggle_quick_terminal

# --- Splits: your workflow is 3-4 dev-server panes ---
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down
keybind = cmd+shift+enter=toggle_split_zoom
keybind = cmd+alt+left=goto_split:left
keybind = cmd+alt+right=goto_split:right
keybind = cmd+alt+up=goto_split:up
keybind = cmd+alt+down=goto_split:down
keybind = cmd+ctrl+left=resize_split:left,40
keybind = cmd+ctrl+right=resize_split:right,40
keybind = cmd+ctrl+up=resize_split:up,20
keybind = cmd+ctrl+down=resize_split:down,20

# --- Tabs ---
keybind = cmd+t=new_tab
keybind = cmd+shift+left=previous_tab
keybind = cmd+shift+right=next_tab

# --- Transition comforts (iTerm2 muscle memory) ---
# Dim inactive splits so the active dev-server pane is obvious at a glance.
unfocused-split-opacity = 0.7
# iTerm2-style clear; Ghostty's default cmd+k only clears the visible screen.
keybind = cmd+k=clear_screen
keybind = cmd+w=close_surface
keybind = cmd+shift+w=close_window
cursor-style = block
cursor-style-blink = true
mouse-hide-while-typing = true
window-padding-x = 4
window-padding-y = 4
# Restore windows/splits on relaunch, like iTerm2.
window-save-state = always
# Mimic iTerm2's fullscreen (no separate Space).
macos-non-native-fullscreen = visible-menu
# Slightly bolder glyphs — closer to iTerm2's rendering weight.
font-thicken = true
resize-overlay = never
quick-terminal-position = top
# Let OSC52 copies from remote ssh sessions reach your local clipboard.
clipboard-read = allow
